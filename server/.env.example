# ===========================================
# AlgoTrade Server - Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit your real .env file to GitHub.
# ===========================================

# --- Server ---
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# --- Auth ---
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d
COOKIE_SECRET=replace_this_with_another_long_random_string

# --- Zerodha Kite Connect ---
# Get these from https://developers.kite.trade after creating a Kite Connect app.
# Kite Connect API access is a paid subscription (~Rs 2000/month) from Zerodha.
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
KITE_REDIRECT_URL=http://localhost:5000/api/broker/kite/callback

# --- Upstox (alternative broker, free API) ---
# Get these from https://upstox.com/developer/apps
UPSTOX_API_KEY=your_upstox_api_key
UPSTOX_API_SECRET=your_upstox_api_secret
UPSTOX_REDIRECT_URL=http://localhost:5000/api/broker/upstox/callback

# --- Strategy Engine ---
# Default capital used for backtest simulations (in INR)
DEFAULT_BACKTEST_CAPITAL=100000
# Risk per trade as a percentage of capital
RISK_PER_TRADE_PCT=1.5

# --- Database ---
DB_PATH=./data/algotrade.db
